# Google OAuth client IDs — copy to `.env` and fill in.
#
# Create these at https://console.cloud.google.com/apis/credentials for a project
# with the Google Drive API enabled.
#
# The iOS client ID is what the app signs in with. The web client ID is required
# by @react-native-google-signin to request a serverAuthCode / idToken; it is not
# a server component (Rushmark has no backend — constitution, Additional
# Constraints), it is just how the library is configured.
#
# The reversed iOS client ID is the URL scheme iOS hands the OAuth callback back
# on. It is the iOS client ID with its dot-separated parts reversed, e.g.
#   1234-abc.apps.googleusercontent.com
#   -> com.googleusercontent.apps.1234-abc

GOOGLE_IOS_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_URL_SCHEME=
